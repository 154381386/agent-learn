APP_ENV=dev
HOST=0.0.0.0
PORT=8000
APPROVAL_DB_PATH=./data/approvals.db
LANGGRAPH_CHECKPOINT_DB=./data/langgraph.db
AGENT_TRANSPORT=local
POD_AGENT_URL=http://localhost:8101/api/v1/agents/pod-analysis/run
RCA_AGENT_URL=http://localhost:8101/api/v1/agents/root-cause/run
NETWORK_AGENT_URL=http://localhost:8101/api/v1/agents/network-diagnosis/run

LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_API_KEY=your-chat-api-key
LLM_MODEL=gpt-5.4
LLM_TIMEOUT_SEC=30
LLM_TEMPERATURE=0.2

RAG_ENABLED=true
RAG_SERVICE_BASE_URL=http://localhost:8200
RAG_SERVICE_TIMEOUT_SEC=30
