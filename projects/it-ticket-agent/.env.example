APP_ENV=dev
HOST=0.0.0.0
PORT=8000
MCP_CONNECTIONS_PATH=./mcp_connections.yaml
STORAGE_BACKEND=postgres
APPROVAL_DB_PATH=./data/approvals.db
POSTGRES_DSN=postgresql://app:app@127.0.0.1:5433/it_ticket_agent_runtime

# LLM_PROVIDER 可选：richado（默认/current）、yuangege（previous）、none。
# 显式 LLM_BASE_URL/LLM_MODEL/LLM_WIRE_API 会覆盖 provider preset。
LLM_PROVIDER=richado
LLM_RICHADO_API_KEY=your-richado-api-key
LLM_YUANGEGE_API_KEY=your-yuangege-api-key
# LLM_API_KEY=optional-global-override
# LLM_BASE_URL=http://richado.qzz.io:8091
# LLM_MODEL=gpt-5.5
# LLM_WIRE_API=responses
LLM_TIMEOUT_SEC=30
LLM_TEMPERATURE=0.2

RAG_ENABLED=true
RAG_SERVICE_BASE_URL=http://localhost:8200
RAG_SERVICE_TIMEOUT_SEC=30
