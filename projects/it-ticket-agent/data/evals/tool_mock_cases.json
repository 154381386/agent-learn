              "max_latency_ms": 4300
            },
            "evidence": [
              "slow_query_count=24",
              "max_latency_ms=4300"
            ]
          },
          "inspect_db_instance_health": {
            "summary": "数据库实例健康退化。",
            "payload": {
              "service": "payment-service",
              "db_health": "degraded"
            },
            "evidence": [
              "db_health=degraded"
            ]
          }
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_connection_pool",
          "inspect_slow_queries",
          "inspect_db_instance_health"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "inspect_connection_pool",
          "inspect_slow_queries",
          "inspect_db_instance_health"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 2,
        "first_forbidden_tools": [
          "check_pod_status",
          "inspect_upstream_dependency",
          "check_recent_deployments"
        ],
        "forbidden_tools": [
          "check_pod_status",
          "inspect_upstream_dependency",
          "check_recent_deployments"
        ],
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 4
      }
    },
    {
