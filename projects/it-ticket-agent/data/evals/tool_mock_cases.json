{
  "schema_version": 2,
  "description": "Real-LLM agent eval cases backed by mocked tool responses only. Covers single-domain convergence, cross-domain expansion, and noisy-signal containment.",
  "cases": [
    {
      "case_id": "network_profile_prefers_network_tools",
      "description": "超时类问题应优先命中网络与上游依赖排查工具，并且首轮不应混入 helper / K8s 工具。",
      "request": {
        "user_id": "eval-network",
        "message": "order service为什么总是超时",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case2",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_ingress_route",
          "inspect_vpc_connectivity",
          "inspect_upstream_dependency"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "inspect_ingress_route",
          "inspect_vpc_connectivity",
          "inspect_upstream_dependency"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 2,
        "first_forbidden_tools": [
          "check_service_health",
          "check_recent_alerts",
          "check_pod_status"
        ],
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 4
      }
    },
    {
      "case_id": "oom_profile_prefers_k8s_tools",
      "description": "OOM / Pod 异常类问题应优先命中 Pod 状态、日志和事件排查工具。",
      "request": {
        "user_id": "eval-oom",
        "message": "order-service pod OOMKilled，帮我排查",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case1",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "check_pod_status",
          "inspect_pod_logs",
          "inspect_pod_events"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "check_pod_status",
          "inspect_pod_logs",
          "inspect_pod_events"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 2,
        "first_forbidden_tools": [
          "check_service_health",
          "check_recent_alerts",
          "inspect_upstream_dependency"
        ],
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 4
      }
    },
    {
      "case_id": "deploy_signals_prefers_cicd_tools",
      "description": "发布回归问题应优先命中 CICD 侧排查工具，而不是盲目走 K8s / 网络面。",
      "request": {
        "user_id": "eval-cicd",
        "message": "checkout-service 刚发布后开始报错，帮我看是不是发布回归",
        "service": "checkout-service",
        "environment": "prod"
      },
      "setup": {
        "mock_tool_responses": {
          "check_recent_deployments": {
            "summary": "checkout-service 在故障窗口前 10 分钟发生过发布。",
            "payload": {
              "service": "checkout-service",
              "has_recent_deploy": true,
              "deploy_count": 1,
              "latest_revision": "2026.04.21-rc1"
            },
            "evidence": [
              "故障窗口前 10 分钟存在 deploy",
              "latest_revision=2026.04.21-rc1"
            ]
          },
          "check_pipeline_status": {
            "summary": "checkout-service 最近一次流水线有失败步骤。",
            "payload": {
              "service": "checkout-service",
              "pipeline_status": "failed",
              "failed_stage": "post-deploy-smoke"
            },
            "evidence": [
              "pipeline_status=failed",
              "failed_stage=post-deploy-smoke"
            ]
          },
          "get_change_records": {
            "summary": "checkout-service 最近变更集中在订单创建逻辑。",
            "payload": {
              "service": "checkout-service",
              "change_count": 2,
              "suspect_component": "order-create"
            },
            "evidence": [
              "change_count=2",
              "suspect_component=order-create"
            ]
          },
          "check_service_health": {
            "summary": "checkout-service 当前错误率升高，但副本仍然可用。",
            "payload": {
              "service": "checkout-service",
              "health_status": "degraded",
              "error_rate_percent": 6.7
            },
            "evidence": [
              "health_status=degraded",
              "error_rate_percent=6.7"
            ]
          }
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "check_recent_deployments",
          "check_pipeline_status",
          "get_change_records"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "check_recent_deployments",
          "check_pipeline_status",
          "get_change_records"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 2,
        "first_forbidden_tools": [
          "check_service_health",
          "inspect_vpc_connectivity",
          "check_pod_status"
        ],
        "forbidden_tools": [
          "inspect_vpc_connectivity"
        ],
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 4
      }
    },
    {
      "case_id": "db_signal_prefers_db_tools",
