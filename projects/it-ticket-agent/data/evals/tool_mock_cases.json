              "quota_state": "exhausted",
              "requested_cpu": 64,
              "available_cpu": 0
            },
            "evidence": [
              "quota_state=exhausted",
              "available_cpu=0"
            ]
          }
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_tools": [
          "get_quota_status"
        ],
        "first_any_tools": [
          "get_quota_status"
        ],
        "first_any_tools_min_matches": 1,
        "first_any_tools_window": 1,
        "first_forbidden_tools": [
          "check_pod_status",
          "inspect_upstream_dependency",
          "check_recent_deployments"
        ],
        "forbidden_tools": [
          "check_pod_status",
          "inspect_upstream_dependency",
          "check_recent_deployments"
        ],
        "expansion_probe_required": false,
        "min_tool_calls_used": 1,
        "max_tool_calls_used": 2
      }
    },
