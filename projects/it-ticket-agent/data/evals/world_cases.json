        "message": "cluster bootstrap 创建失败，提示 quota 不足",
        "service": "cluster-bootstrap",
        "environment": "prod"
      },
      "setup": {
        "world_state": {
          "service": "cluster-bootstrap",
          "root_cause": "quota_exhausted",
          "timeline": {
            "symptom_started_minutes_ago": 2
          },
          "signals": {
