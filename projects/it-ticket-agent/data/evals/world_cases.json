{
  "schema_version": 1,
  "description": "Mock-world profile eval cases. Tool outputs are loaded from data/mock_case_profiles.json so every readonly tool has a coherent response for the selected world.",
  "gate": {
    "min_pass_rate": 0.8,
    "max_avg_tool_calls_used": 5.2,
    "max_expansion_probe_cases": 5,
    "max_rejected_tool_call_total": 1
  },
  "cases": [
    {
      "case_id": "world_timeout_db_pool_with_network_noise",
      "description": "表面像网络 timeout，但真实根因来自 DB 连接池饱和；同时保留轻微上游抖动和最近发布作为噪声。",
      "request": {
        "user_id": "world-db-timeout",
        "message": "order-service 为什么一直 timeout，gateway 偶尔 502",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case4_db_pool_saturation",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_connection_pool",
          "inspect_slow_queries",
          "inspect_db_instance_health"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "inspect_ingress_route",
          "inspect_vpc_connectivity",
          "inspect_upstream_dependency",
          "inspect_load_balancer_status"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 3,
        "expanded_domains": [
          "db"
        ],
        "expansion_probe_required": true,
        "min_tool_calls_used": 3,
        "max_tool_calls_used": 6
      }
    },
    {
      "case_id": "world_deploy_signal_expands_to_k8s_oom",
      "description": "消息显式指向发布，但发布链路只提供弱证据，真实异常在 K8s OOM。",
      "request": {
        "user_id": "world-cicd-k8s",
        "message": "order-service 刚发完版后开始报错，发布看着成功，帮我定位",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case1",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "check_pod_status",
          "inspect_pod_logs",
          "inspect_pod_events"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "check_recent_deployments",
          "check_pipeline_status",
          "get_change_records"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 3,
        "expanded_domains": [
          "k8s"
        ],
        "expansion_probe_required": true,
        "min_tool_calls_used": 3,
        "max_tool_calls_used": 6
      }
    },
    {
      "case_id": "world_strong_network_outage_stays_network",
      "description": "共享事故世界里网络侧已有强异常证据，应直接停在网络域。",
      "request": {
        "user_id": "world-network-strong",
        "message": "order-service gateway 502 很多，upstream timeout 也在涨",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case7_ingress_lb_vpc_block",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_ingress_route",
          "inspect_vpc_connectivity",
          "inspect_upstream_dependency",
          "inspect_load_balancer_status"
        ],
        "required_any_tools_min_matches": 2,
        "expansion_probe_required": false,
        "forbidden_tools": [
          "inspect_connection_pool",
          "check_recent_deployments",
          "check_pod_status"
        ],
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 4
      }
    },
    {
      "case_id": "world_db_signal_expands_to_network_block",
      "description": "消息像 DB 问题，但共享事故世界里 DB 正常、网络阻塞，要求从 DB 扩到 network。",
      "request": {
        "user_id": "world-db-network",
        "message": "order-service 查询很慢，看起来像数据库有问题",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case2",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_upstream_dependency",
          "inspect_vpc_connectivity",
          "inspect_ingress_route"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "inspect_connection_pool",
          "inspect_slow_queries",
          "inspect_db_instance_health"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 3,
        "expanded_domains": [
          "network"
        ],
        "expansion_probe_required": true,
        "min_tool_calls_used": 3,
        "max_tool_calls_used": 6
      }
    },
    {
      "case_id": "world_quota_exhaustion_single_domain",
      "description": "共享事故世界里的 quota 枯竭应直接被 SDE 工具命中，不需要跨域。",
      "request": {
        "user_id": "world-sde",
        "message": "order-service 新环境创建失败，提示 quota 不足",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case5_sde_quota_exhausted",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_tools": [
          "get_quota_status"
        ],
        "first_any_tools": [
          "get_quota_status"
        ],
        "first_any_tools_min_matches": 1,
        "first_any_tools_window": 1,
        "expansion_probe_required": false,
        "min_tool_calls_used": 1,
        "max_tool_calls_used": 2
      }
    },
    {
      "case_id": "world_cpu_thread_pool_saturation",
      "description": "完整 mock 世界里的 CPU/thread pool 饱和，应由 runtime resource tools 收敛。",
      "request": {
        "user_id": "world-cpu-thread",
        "message": "order-service CPU 很高，线程池队列堆积，请完整排查根因",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case6_cpu_thread_saturation",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "inspect_cpu_saturation",
          "inspect_thread_pool_status",
          "inspect_pod_logs"
        ],
        "required_any_tools_min_matches": 2,
        "first_any_tools": [
          "check_pod_status",
          "inspect_cpu_saturation",
          "inspect_thread_pool_status",
          "inspect_pod_logs"
        ],
        "first_any_tools_min_matches": 2,
        "first_any_tools_window": 4,
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 5
      }
    },
    {
      "case_id": "world_canary_regression_stays_cicd",
      "description": "完整 mock 世界里的 canary 发布失败，应直接留在 CICD/canary 证据链。",
      "request": {
        "user_id": "world-canary",
        "message": "order-service 灰度发布失败，canary analysis 报错，帮我定位是否需要回滚",
        "service": "order-service",
        "environment": "prod"
      },
      "setup": {
        "tool_profile": {
          "case_id": "case8_canary_release_regression",
          "service": "order-service"
        }
      },
      "expect": {
        "status": "completed",
        "route": "react_tool_first",
        "required_any_tools": [
          "check_canary_status",
          "check_pipeline_status",
          "get_deployment_status",
          "get_change_records",
          "get_rollback_history"
        ],
        "required_any_tools_min_matches": 2,
        "expansion_probe_required": false,
        "min_tool_calls_used": 2,
        "max_tool_calls_used": 5
      }
    }
  ]
}
